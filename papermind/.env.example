# 主力 LLM（阿里云 DashScope）
QWEN_API_KEY=your_dashscope_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash
# 同一个阿里云 Key 下的备用千问模型（逗号分隔，按顺序尝试）
# QWEN_FALLBACK_MODELS=qwen-flash-2025-07-28,qwen-plus

# 备选 LLM（智谱 GLM）
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# 备选 LLM（DeepSeek）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Owner 设备 ID（不限速）
OWNER_UID=

# 每日限速配置（可选，不填则使用默认值）
DAILY_RECOMMEND_LIMIT=8    # 每人每天获取推荐结果的批次数
DAILY_CHAT_LIMIT=20        # 每人每天 AI 对话次数
DAILY_TRANSLATE_LIMIT=30   # 每人每天翻译次数
GLOBAL_DAILY_CHAT_LIMIT=500  # 全局每日 AI 对话熔断（所有用户之和）

# CORS 允许来源（有域名后填写，多个用逗号分隔；不填则允许所有来源）
# ALLOWED_ORIGINS=https://yourdomain.com
